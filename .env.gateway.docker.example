# Magister Gateway — Local Docker Dev Environment
# Copy to .env.gateway.docker and fill in values from `supabase status`

# Supabase (use host.docker.internal to reach host-bound Supabase)
SUPABASE_URL=http://host.docker.internal:54321
SUPABASE_SERVICE_ROLE_KEY=<from supabase status>
SUPABASE_JWT_SECRET=<from supabase status>

# Anthropic
ANTHROPIC_API_KEY=<your-anthropic-api-key>

# Gateway API key (used by Vercel webhook for provision/destroy)
GATEWAY_API_KEY=dev-gateway-api-key-local-unsafe

# Local dev: route chat/health to Docker service instead of Fly internal DNS
DEV_MACHINE_URL=http://user-machine:18789

# OpenClaw image (set after running: docker build -t magister-openclaw:local ./openclaw-image)
OPENCLAW_IMAGE=magister-openclaw:local

# Dev machine token (must match gateway_token in seed migration)
DEV_GATEWAY_TOKEN=dev-local-token-magister-2026

# Slack integration (optional — only needed if testing Slack locally)
# Create a Slack app at https://api.slack.com/apps and fill these in.
# SLACK_CLIENT_ID=
# SLACK_CLIENT_SECRET=
# SLACK_SIGNING_SECRET=
# SLACK_APP_ID=
# WEBAPP_URL=http://localhost:3020
